rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidDate(d) {
      return d is string && d.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isValidHour(h) {
      return h is int && h >= 0 && h <= 23;
    }

    function isValidBookingCode(code) {
      return code is string && code.matches('^\\d{6}$');
    }

    function isValidClient(c) {
      return c is map
        && c.keys().hasOnly(['name', 'phone', 'phoneNormalized', 'email'])
        && c.name is string
        && c.name.size() > 0
        && c.name.size() <= 120
        && c.phone is string
        && c.phone.size() > 0
        && c.phone.size() <= 30
        && c.phoneNormalized is string
        && c.phoneNormalized.matches('^\\d{7,15}$')
        && c.email is string
        && c.email.size() <= 200;
    }

    function isValidService(s) {
      return s is map
        && s.keys().hasOnly(['id', 'name', 'duration'])
        && s.id is string
        && s.id.size() > 0
        && s.id.size() <= 40
        && s.name is string
        && s.name.size() > 0
        && s.name.size() <= 80
        && s.duration is int
        && s.duration >= 15
        && s.duration <= 240;
    }

    function isValidManageProof(p, data) {
      return p is map
        && p.keys().hasOnly(['bookingCode', 'phoneNormalized', 'phone'])
        && p.bookingCode is string
        && p.bookingCode.matches('^\\d{6}$')
        // Enforce booking-code match when stored as string; tolerate legacy non-string values.
        && (!(data.bookingCode is string) || p.bookingCode == data.bookingCode)
        && p.phoneNormalized is string
        && p.phoneNormalized.matches('^\\d{7,15}$')
        // Enforce phoneNormalized match when present on the stored booking.
        && (!((data.client is map) && (data.client.phoneNormalized is string))
          || p.phoneNormalized == data.client.phoneNormalized)
        && (!p.keys().hasAny(['phone'])
          || (p.phone is string && p.phone.size() > 0 && p.phone.size() <= 30));
    }

    function isValidBookingData(data) {
      return data.keys().hasOnly(['hour', 'label', 'bookingCode', 'status', 'client', 'service', 'date', 'createdAt'])
        && isValidDate(data.date)
        && isValidHour(data.hour)
        && data.label is string
        && data.label.size() > 0
        && data.label.size() <= 30
        && isValidBookingCode(data.bookingCode)
        && isValidClient(data.client)
        && isValidService(data['service'])
        && (!data.keys().hasAny(['status']) || data.status == 'active');
    }

    function isValidCancellationUpdate(resourceData, requestData) {
      return requestData.diff(resourceData).affectedKeys().hasOnly(['status', 'cancelledAt', 'movedTo', 'manageProof'])
        && requestData.status == 'cancelled'
        && requestData.cancelledAt is timestamp
        && (
          !requestData.diff(resourceData).affectedKeys().hasAny(['movedTo'])
          || (requestData.movedTo is string && requestData.movedTo.matches('^\\d{4}-\\d{2}-\\d{2}_[0-9]{1,2}$'))
        )
        && (
          !requestData.diff(resourceData).affectedKeys().hasAny(['manageProof'])
          || isValidManageProof(requestData.manageProof, resourceData)
        );
    }

    function isValidRebookingUpdate(resourceData, requestData) {
      return resourceData.status == 'cancelled'
        && isValidBookingData(requestData)
        && requestData.date == resourceData.date
        && requestData.hour == resourceData.hour;
    }

    match /bookings/{bookingId} {
      allow get, list: if true;

      allow create: if isValidBookingData(request.resource.data)
        && bookingId.matches('^\\d{4}-\\d{2}-\\d{2}_[0-9]{1,2}$')
        && !exists(/databases/$(database)/documents/bookings/$(bookingId));

      allow update: if (
          isValidCancellationUpdate(resource.data, request.resource.data)
          && resource.data.status != 'cancelled'
        ) || isValidRebookingUpdate(resource.data, request.resource.data);

      allow delete: if true;
    }
  }
}
